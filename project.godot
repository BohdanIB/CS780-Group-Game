; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CS780 Group Project"
run/main_scene="res://Scenes/start_menu.tscn"
config/features=PackedStringArray("4.6", "C#", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameSettings="*uid://doh0wtguuc37u"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/borderless=true
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="CS780 Group Project"

[editor_plugins]

enabled=PackedStringArray()

[file_customization]

folder_colors={
"res://Assets/": "orange",
"res://Resources/": "blue",
"res://Scenes/": "teal",
"res://Scripts/": "purple",
"res://Testing/": "pink"
}

[gdunit4]

settings/common/update_notification_enabled=false
settings/test/test_lookup_folder="Testing"

[global_group]

